rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "manamedruby@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == "admin"));
    }

    function isStudent(studentData) {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == studentData.get('gmail', '').lower() || 
         request.auth.token.email.lower() == studentData.get('email_truong', '').lower());
    }

    function isHistoryOwner(historyData) {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == historyData.get('studentEmail', '').lower() || 
         request.auth.token.email.lower() == historyData.get('studentEmailTruong', '').lower());
    }

    function isValidStudent(data) {
      return data.ma_sinh_vien is string && data.ma_sinh_vien.size() > 0 &&
             data.ho_ten is string && data.ho_ten.size() > 0;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Admins can read all. Students can read their own record.
      allow read: if isAdmin() || isStudent(resource.data);
      
      // Only admins can create students.
      allow create: if isAdmin() && isValidStudent(request.resource.data);
      
      // Admins can update all. 
      // Students can update their own record ONLY if allow_edit is true.
      allow update: if (isAdmin() && isValidStudent(request.resource.data)) || 
                      (isStudent(resource.data) && 
                       resource.data.get('allow_edit', false) == true && 
                       isValidStudent(request.resource.data) &&
                       // Prevent students from changing their own allow_edit status or other sensitive fields
                       request.resource.data.get('allow_edit', false) == resource.data.get('allow_edit', false) &&
                       request.resource.data.get('gmail', '') == resource.data.get('gmail', '') &&
                       request.resource.data.get('ma_sinh_vien', '') == resource.data.get('ma_sinh_vien', ''));
      
      allow delete: if isAdmin();
    }

    match /history/{historyId} {
      // Admins can read all history.
      // Students can read history related to them using denormalized email.
      allow read: if isAdmin() || isHistoryOwner(resource.data);
      
      // Only admins or the system (via admin) can create history.
      // In this app, we'll allow authenticated users to create history if it's about them (e.g. they edited their profile)
      // or if they are admin.
      allow create: if isAdmin() || (isAuthenticated() && isHistoryOwner(request.resource.data));
      
      // History should be immutable once created, or only admin can update (e.g. to mark as read)
      // Students can update readBy to mark as read.
      allow update: if isAdmin() || 
                      (isHistoryOwner(resource.data) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if isAdmin();
    }

    match /update_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email.lower() == resource.data.get('studentEmail', '').lower());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email.lower() == resource.data.get('studentEmail', '').lower());
      allow write: if isAdmin();
    }

    match /chat_messages/{messageId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email.lower() == resource.data.get('studentEmail', '').lower());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
